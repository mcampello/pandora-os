# Copie para .env e preencha. O .env é gitignored.
# Token = credentials.instance_token do connector 'whatsapp' da Pandora OS
# (Supabase: select credentials from connectors where type='whatsapp')
UAZAPI_TOKEN=
UAZAPI_BASE_URL=https://pandora.uazapi.com

# Formato do endpoint de mídia. A doc v2 do uazapi usa type/file (default).
# Se o envio de mídia falhar, tente v1 (mediatype/media), que é o formato
# usado pelo helper atual do Pandora OS em src/lib/uazapi.ts.
UAZAPI_MEDIA_FORMAT=v2
